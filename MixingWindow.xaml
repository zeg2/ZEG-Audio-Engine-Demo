<Window x:Class="ZEGAudioEngineAI.MixingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZEGAudioEngineAI"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="MIXING"
        Width="1280"
        Height="760"
        Background="#061427"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>

        <!-- ===== Neon brushes ===== -->
        <SolidColorBrush x:Key="NavyBg" Color="#05070D"/>
        <SolidColorBrush x:Key="PanelBg" Color="#07101D"/>
        <SolidColorBrush x:Key="PanelBg2" Color="#081427"/>
        <SolidColorBrush x:Key="Stroke" Color="#173B55"/>
        <SolidColorBrush x:Key="Neon" Color="#2AA8FF"/>
        <SolidColorBrush x:Key="TextMain" Color="#E6FBFF"/>
        <SolidColorBrush x:Key="TextDim" Color="#88BFE9FF"/>
        <local:DbToBrushConverter x:Key="DbToBrush"/>
        <local:ProgressToScaleConverter x:Key="ProgressToScale"/>
        <local:DbToHeightConverter x:Key="DbToHeight"/>
        <local:DbToTipBrushConverter x:Key="DbToTipBrush"/>
        <local:DbToOverlayHeightConverter x:Key="DbToOverlayHeight"/>
        <local:KnobArcConverter x:Key="KnobArc"/>
        <local:KnobDashArrayConverter x:Key="KnobDashArray"/>
        <local:KnobDashOffsetConverter x:Key="KnobDashOffset"/>
        <local:DbToHeightDynamicConverter x:Key="DbToHeightDynamic"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        
        <!-- ===== Slider style: dark track + 3D glow cap ===== -->
        <Style x:Key="NeonSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>

                            <!-- Dark SSL-ish track -->
                            <Border Height="8"
                            VerticalAlignment="Center"
                            CornerRadius="5"
                            Background="#03101F"
                            BorderBrush="#1B3E5A"
                            BorderThickness="1"/>

                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                          Opacity="0"
                                          IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                          Opacity="0"
                                          IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>

                                <!-- SSL CAP -->
                                <Track.Thumb>
                                    <Thumb Width="22" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Grid x:Name="Root" Width="22" Height="22">

                                                    <!-- subtle glow -->
                                                    <Border CornerRadius="4" Opacity="0.7">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#00A6FF"
                                                                      BlurRadius="10"
                                                                      ShadowDepth="0"
                                                                      Opacity="0.55"/>
                                                        </Border.Effect>
                                                    </Border>

                                                    <!-- cap body -->
                                                    <Border CornerRadius="4"
                                                    BorderThickness="1"
                                                    BorderBrush="#6EC9FF"
                                                    Background="#0B2A4A">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#000000"
                                                                      BlurRadius="6"
                                                                      ShadowDepth="2"
                                                                      Opacity="0.45"/>
                                                        </Border.Effect>
                                                    </Border>

                                                    <!-- 3 RED LINES (SSL style) -->
                                                    <Grid Margin="4,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        Background="#FF2A2A"
                                                        HorizontalAlignment="Center"/>

                                                        <Border Grid.Column="1"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        Background="#FF2A2A"
                                                        HorizontalAlignment="Center"/>

                                                        <Border Grid.Column="2"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        Background="#FF2A2A"
                                                        HorizontalAlignment="Center"/>
                                                    </Grid>

                                                    <!-- tiny highlight -->
                                                    <Border CornerRadius="4" Margin="1" Opacity="0.25">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                </Grid>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter TargetName="Root" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.06" ScaleY="1.06"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>

                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="Root" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter TargetName="Root" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Small neon button style (local to this window) ===== -->
        <Style x:Key="NeonSmallButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Neon}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#0B2A4A"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- ===== Toggle (FX) style ===== -->
        <Style x:Key="FxToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="88"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2AA8FF"/>
            <Setter Property="Background" Value="#07101D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="B"
                                CornerRadius="8"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#0B3B66"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter TargetName="B" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#7AD7FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter TargetName="B" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E6FBFF"/>
            <Setter Property="Background" Value="#0B1F38"/>
            <Setter Property="BorderBrush" Value="#2AA8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"/>
                                                <Setter Property="FontSize"
                                                Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=FontSize}"/>
                                                <Setter Property="FontWeight"
                                                Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=FontWeight}"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>

                                    <ToggleButton x:Name="PART_DropDownToggle"
                                          Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                        <Path VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#BFE9FF"
                                      Data="M 0 0 L 6 6 L 12 0 Z"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                                <Border CornerRadius="10"
                                Background="#061427"
                                BorderBrush="#2AA8FF"
                                BorderThickness="1"
                                Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7AD7FF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E6FBFF"/>
                        <Setter Property="Background" Value="#061427"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#0B2A4A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0B3B66"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MeterProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="#061427"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True" Background="{TemplateBinding Background}">
                            <Border CornerRadius="6" Background="{TemplateBinding Background}"/>

                            <!-- Indicator fills from bottom -->
                            <Border CornerRadius="6"
                            Background="{TemplateBinding Foreground}"
                            VerticalAlignment="Bottom"
                            RenderTransformOrigin="0.5,1">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1">
                                        <ScaleTransform.ScaleY>
                                            <MultiBinding Converter="{StaticResource ProgressToScale}">
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                            </MultiBinding>
                                        </ScaleTransform.ScaleY>
                                    </ScaleTransform>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== KNOB STYLE (EQ/COMP/IMG/LIM) - PERFECT CIRCLE RING ===================== -->
        <Style x:Key="NeonKnobStyle" TargetType="{x:Type Slider}">
            <!-- Size -->
            <Setter Property="Width" Value="61"/>
            <Setter Property="Height" Value="61"/>

            <!-- Range -->
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>

            <!-- Prevent jump-to-point -->
            <Setter Property="IsMoveToPointEnabled" Value="False"/>

            <!-- Drag handlers (vertical knob drag) -->
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Knob_MouseDown"/>
            <EventSetter Event="PreviewMouseMove" Handler="Knob_MouseMove"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="Knob_MouseUp"/>
            <EventSetter Event="LostMouseCapture" Handler="Knob_LostMouseCapture"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Width="{TemplateBinding Width}"
                      Height="{TemplateBinding Height}"
                      Background="Transparent">

                            <!-- Base -->
                            <Ellipse Fill="#11161E"
                             Stroke="#1B2A3A"
                             StrokeThickness="2"
                             IsHitTestVisible="False"/>

                            <!-- Empty ring -->
                            <Ellipse Stroke="#2A3442"
                             StrokeThickness="5"
                             Opacity="0.9"
                             Margin="8"
                             Fill="Transparent"
                             IsHitTestVisible="False"/>

                            <!-- Progress ring (perfect circle via dash) -->
                            <Ellipse Stroke="#A855FF"
                             StrokeThickness="5"
                             StrokeStartLineCap="Round"
                             StrokeEndLineCap="Round"
                             StrokeLineJoin="Round"
                             Margin="8"
                             Fill="Transparent"
                             IsHitTestVisible="False">
                                <Ellipse.StrokeDashArray>
                                    <MultiBinding Converter="{StaticResource KnobDashArray}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Width"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Height"/>
                                        <Binding Source="8"/>
                                        <Binding Source="5"/>
                                    </MultiBinding>
                                </Ellipse.StrokeDashArray>

                                <Ellipse.StrokeDashOffset>
                                    <MultiBinding Converter="{StaticResource KnobDashOffset}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Width"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Height"/>
                                        <Binding Source="8"/>
                                        <Binding Source="5"/>
                                    </MultiBinding>
                                </Ellipse.StrokeDashOffset>
                            </Ellipse>

                            <!-- Inner face -->
                            <Ellipse Fill="#0B0F15"
                             Margin="12"
                             IsHitTestVisible="False"/>

                            <!-- Center cap -->
                            <Ellipse Fill="#0A0D12"
                             Margin="22"
                             Stroke="#243449"
                             StrokeThickness="1"
                             IsHitTestVisible="False"/>

                            <!-- Value text -->
                            <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, StringFormat={}{0:0}}"
                               Foreground="#E6FBFF"
                               FontWeight="SemiBold"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WaveformBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="520"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#0B1A26"/>
            <Setter Property="BorderBrush" Value="#2AA8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00C8FF"
                              BlurRadius="16"
                              ShadowDepth="0"
                              Opacity="0.35"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WaveformPathStyle" TargetType="{x:Type Path}">
            <Setter Property="Stroke" Value="#2AA8FF"/>
            <Setter Property="StrokeThickness" Value="1.2"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Fill" Value="#132B3A"/>
            <Setter Property="Opacity" Value="0.95"/>
        </Style>


        <Style x:Key="NeonExportComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E6FBFF"/>
            <Setter Property="Background" Value="#0B1F38"/>
            <Setter Property="BorderBrush" Value="#2AA8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selected item -->
                                    <ContentPresenter Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>

                                    <!-- Arrow -->
                                    <ToggleButton x:Name="PART_DropDownToggle"
                                          Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                        <Path VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#BFE9FF"
                                      Data="M 0 0 L 6 6 L 12 0 Z"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Dropdown -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                                <Border CornerRadius="10"
                                Background="#061427"
                                BorderBrush="#2AA8FF"
                                BorderThickness="1"
                                Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7AD7FF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Items (να φαίνονται καθαρά) -->
        <Style x:Key="NeonExportComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E6FBFF"/>
            <Setter Property="Background" Value="#061427"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#0B2A4A"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0B3B66"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NeonComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E6FBFF"/>
            <Setter Property="Background" Value="#0B1F38"/>
            <Setter Property="BorderBrush" Value="#2AA8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                            CornerRadius="6"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"/>
                                                <Setter Property="FontSize" Value="14"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>

                                    <ToggleButton x:Name="PART_DropDownToggle"
                                          Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                        <Path VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#BFE9FF"
                                      Data="M 0 0 L 6 6 L 12 0 Z"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                                <Border CornerRadius="8"
                                Background="#061427"
                                BorderBrush="#2AA8FF"
                                BorderThickness="1"
                                Padding="6">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7AD7FF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>


                                        VerticalAlignment="Top">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0"
    Text="OCTAVE&#10;SHIFT"
    TextAlignment="Center"
    Foreground="#BFE9FF"
    FontWeight="Bold"
    FontSize="11"
    HorizontalAlignment="Center"
    Margin="0,0,0,0"/>
                                                                <Slider Grid.Row="1"
    Style="{StaticResource NeonKnobStyle}"
    Value="{Binding FxOctaveMixPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBlock Grid.Row="2"
                                                   Text="MIX"
                                                   Foreground="#8BBFE9"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,6"/>
                                                                <Button Grid.Row="4"
                                                Content="EDIT"
                                                Height="22"
                                                Width="72"
                                                Click="FxEditButton_Click"
                                                Tag="OCTAVE"                                              
                                                Background="#081421"
                                                Foreground="#D8F4FF"
                                                BorderBrush="#2AA8FF"
                                                BorderThickness="1"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                VerticalAlignment="Bottom"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>

                                                <Border Grid.Row="3" Background="Transparent"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Grid>

        </Border>
        <!-- ===================== TTS POPUP OVERLAY ===================== -->
        <Grid x:Name="TtsOverlay"
      Visibility="Collapsed"
      Background="#99000000"
      Panel.ZIndex="9999"
      MouseDown="TtsOverlay_BackgroundMouseDown">

            <Border Width="760"
            MaxWidth="900"
            CornerRadius="18"
            BorderBrush="#2AA8FF"
            BorderThickness="2"
            Background="#071A2E"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#00C8FF" BlurRadius="22" ShadowDepth="0" Opacity="0.35"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="OFFLINE TTS (Speech → Track)"
                           Foreground="#E6FBFF"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                        Content="×"
                        Width="34"
                        Height="34"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#0B1F38"
                        Foreground="#E6FBFF"
                        BorderBrush="#2AA8FF"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="TtsCloseButton_Click"/>
                    </Grid>

                    <!-- Voice pack + text -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Voice Pack"
                               Foreground="#BFE9FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                            <ComboBox x:Name="VoicePackCombo"
                              Height="30"
                              Style="{StaticResource TtsNeonComboStyle}"

                              Foreground="#E6FBFF"
                              Background="#0B1F38"
                              BorderBrush="#2AA8FF"
                              BorderThickness="1"
                              FontSize="14"
                              FontWeight="SemiBold"
                              Padding="8,0"
                              MaxDropDownHeight="260"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Text"
                               Foreground="#BFE9FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                            <TextBox x:Name="TtsTextBox"
                             Height="30"
                             Text="Lets make some music!"
                             Foreground="#E6FBFF"
                             Background="#0B1F38"
                             BorderBrush="#2AA8FF"
                             BorderThickness="1"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Padding="10,3,10,3"/>
                        </StackPanel>
                    </Grid>

                    <!-- Timing / Loop row -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Start time -->
                        <Border Grid.Column="0"
                        CornerRadius="12"
                        BorderBrush="#163B66"
                        BorderThickness="1"
                        Background="#061427"
                        Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Start Time (sec)"
                                   Foreground="#0B1F38"
                                   FontSize="14"
                                   FontWeight="Bold"/>

                                <TextBlock Grid.Row="2"
                                   Text="When the generated vocals will enter the track timeline (e.g. 2.45 sec)."
                                   Foreground="#77B9D6"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,36,0,0">
                                    <TextBox x:Name="TtsStartSecBox"
                                     Width="110"
                                     Height="30"
                                     Text="0.00"
                                             
                                     Foreground="#E6FBFF"
                                     Background="#0B1F38"
                                     BorderBrush="#2AA8FF"
                                     BorderThickness="1"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Padding="10,3,10,3"
                                     LostFocus="TtsStartSecBox_LostFocus"/>
                                    <TextBlock Text="sec"
                                       Foreground="#BFE9FF"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Loop -->
                        <Border Grid.Column="2"
                        CornerRadius="12"
                        BorderBrush="#163B66"
                        BorderThickness="1"
                        Background="#061427"
                                
                        Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Loop"
                                   Foreground="#E6FBFF"
                                   FontSize="14"
                                                  

                                   FontWeight="Bold"/>

                                <TextBlock Grid.Row="2"
                                   Text="How many times to repeat the generated clip (0 = play once)."
                                   Foreground="#77B9D6"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,36,0,0">
                                    <ComboBox x:Name="TtsLoopCountCombo"
                                      Width="110"
                                      Height="30"
                                      Foreground="#E6FBFF"
                                      Background="#0B1F38"
                                      BorderBrush="#2AA8FF"
                                                                        Style="{StaticResource TtsNeonComboStyle}"
    
                                      BorderThickness="1"
                                      FontSize="14"
                                      FontWeight="SemiBold"
                                      Padding="8,0"
                                      SelectedIndex="0">
                                        <ComboBoxItem Content="0"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="8"/>
                                    </ComboBox>
                                    <TextBlock Text="times"
                                       Foreground="#BFE9FF"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer buttons -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tip: Each Generate creates a new track slot (does not overwrite previous clips)."
                           Foreground="#77B9D6"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                        Content="CANCEL"
                        Width="140"
                        Height="34"
                        Click="TtsCloseButton_Click"
                        Style="{StaticResource NeonSmallButton}"/>

                        <Button Grid.Column="4"
                        Content="GENERATE TTS WAV"
                        Width="220"
                        Height="34"
                        Click="BtnGenerateTts_Click"
                        Style="{StaticResource NeonSmallButton}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <!-- FINALIZE OVERLAY (WINDOW) -->
                    <Grid x:Name="FinalizeOverlay"
      Visibility="Collapsed"
      Panel.ZIndex="9999">

                        <!-- dark background -->
                        <Border Background="#AA000000"
            MouseDown="FinalizeOverlay_BackgroundMouseDown"/>

                        <!-- center window -->
                        <Border Width="520"
            CornerRadius="14"
            BorderThickness="1"
            BorderBrush="#2AA8FF"
            Background="#061427"
            Padding="18"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#00A6FF" BlurRadius="28" ShadowDepth="0" Opacity="0.65"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="DetectedKeyText"
           Text="Detected: —"
           Foreground="#7EE6FF"
           FontSize="15"
           FontWeight="SemiBold"
           Margin="0,10,0,8"/>

                                <!-- OPTIONS -->
                                <StackPanel Grid.Row="2">

                                    <TextBlock Text="Format"
               Foreground="#BFE9FF"
               FontSize="14"
               FontWeight="SemiBold"
               Margin="0,0,0,8"/>

                                    <RadioButton x:Name="RbApplyWav32f"
                 Content="WAV 32F (Float)"
                 IsChecked="True"
                 Foreground="#E6FBFF"
                 FontSize="15"
                 FontWeight="SemiBold"
                 Margin="2,2,0,2"/>

                                    <RadioButton x:Name="RbApplyWav24"
                 Content="WAV 24BIT"
                 Foreground="#E6FBFF"
                 FontSize="15"
                 FontWeight="SemiBold"
                 Margin="2,2,0,10"/>

                                    <!-- ✅ space before name -->
                                    <TextBox x:Name="ExportNameBox"
             Style="{StaticResource NeonTextBoxStyle}"
             Height="30"
             Margin="0,6,0,0"
             Text="MakisZeginis"
             Foreground="#E6FBFF"
             Background="#0B1F38"
             BorderBrush="#2AA8FF"
             BorderThickness="1"
             FontSize="14"
             FontWeight="SemiBold"
             Padding="10,3,10,3"/>

                                    <!-- Export Bus Preset -->
                                    <TextBlock Text="Export Bus Preset"
               Foreground="#BFE9FF"
               FontSize="14"
               FontWeight="SemiBold"
               Margin="0,16,0,8"/>

                                    <ComboBox x:Name="ExportBusPresetCombo"
                                            Style="{StaticResource NeonExportComboStyle}"

          Width="320"
          Height="30"
          SelectedIndex="0"
          Foreground="#E6FBFF"
          Background="#0B1F38"
          BorderBrush="#2AA8FF"
          BorderThickness="1"
          FontSize="15"
          FontWeight="SemiBold"
          Padding="8,0">
                                        <ComboBoxItem Content="MIXING (Gentle / Wide Dynamics)" Tag="Main"
                  Style="{StaticResource NeonExportComboItemStyle}"/>
                                        <ComboBoxItem Content="EXPORT (Clean / Safety Only)" Tag="ExportClean"
                  Style="{StaticResource NeonExportComboItemStyle}"/>
                                        <ComboBoxItem Content="EXPORT (Glue / Light Cohesion)" Tag="ExportGlue"
                  Style="{StaticResource NeonExportComboItemStyle}"/>
                                        <ComboBoxItem Content="EXPORT (Punch / Tighter Drums)" Tag="ExportPunch"
                  Style="{StaticResource NeonExportComboItemStyle}"/>
                                    </ComboBox>
                                    <CheckBox x:Name="ChkApplyNormalize"
                          Content="Normalize (Peak)"
                          IsChecked="False"                                  
                          Foreground="#E6FBFF"
                          FontSize="15"
                          FontWeight="SemiBold"
                          Margin="2,12,0,0"/>
                                </StackPanel>

                                <!-- ACTIONS -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                        Content="CANCEL"
                        Height="34"
                        Click="FinalizeCancel_Click"
                        Background="#0B2A4A"
                        Foreground="#E6FBFF"
                        BorderBrush="#2AA8FF"
                        BorderThickness="1"
                        FontWeight="Bold"/>



                                    <Button Grid.Column="4"
                        Content="EXPORT WAV"
                        Height="34"
                        Click="FinalizeExport_Click"
                        Background="#0B2A4A"
                        Foreground="#F2FDFF"
                        BorderBrush="#00C8FF"
                        BorderThickness="1"
                        FontWeight="Bold"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Viewbox>
        </Grid>
    </Border>
</Window>